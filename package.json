{
  "name": "siyuan-plugin-vite-vue-sn",
  "type": "module",
  "version": "1.0.2",
  "description": "SN plugin collection for SiYuan Note, providing 25+ practical features including table of contents, image compression, word query, AI content generation, and more",
  "author": "sn",
  "license": "MIT",
  "homepage": "https://gitee.com/kaiouyang-sn/siyuan-plugin-vite-vue-sn",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/kaiouyang-sn/siyuan-plugin-vite-vue-sn.git"
  },
  "keywords": [
    "siyuan",
    "plugin",
    "vite",
    "vue3",
    "typescript",
    "siyuan-note"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "release": "node ./release.js",
    "release:manual": "node ./release.js --mode=manual",
    "release:patch": "node ./release.js --mode=patch",
    "release:minor": "node ./release.js --mode=minor",
    "release:major": "node ./release.js --mode=major",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate:icons": "node scripts/validate-icons.mjs",
    "i18n:merge": "node scripts/merge-i18n.mjs",
    "i18n:verify": "node scripts/verify-i18n.mjs",
    "i18n:split": "node scripts/split-i18n.mjs"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@types/video.js": "^7.3.58",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "diff-match-patch": "^1.0.5",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "marked": "^17.0.1",
    "qrcode": "^1.5.4",
    "video.js": "^8.23.4",
    "vue": "^3.3.8",
    "vue-chartjs": "^5.3.3",
    "vue-diff": "^1.2.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.8.1",
    "@iconify/json": "^2.2.417",
    "@iconify/utils": "^3.1.0",
    "@types/node": "^20.2.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-perfectionist": "^4.2.0",
    "fast-glob": "^3.2.12",
    "minimist": "^1.2.8",
    "rollup-plugin-livereload": "^2.0.5",
    "sass": "^1.62.1",
    "siyuan": "1.1.0",
    "typescript": "^5.0.4",
    "vite": "^6.4.3",
    "vite-plugin-static-copy": "^0.15.0",
    "vite-plugin-zip-pack": "^1.0.5"
  }
}
